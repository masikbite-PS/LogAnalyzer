<Window x:Class="LogAnalyzer.TextileExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export to Textile" Height="600" Width="800" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="15" Background="#F5F5F5">
            <TextBlock Text="Textile Format (for Redmine)" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Text="You can copy this text and paste it directly into Redmine tickets or comments."
                       FontSize="10" Foreground="#555" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="15,0,15,0" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="TextileTextBox" Text="{Binding TextileContent, Mode=OneWay}"
                     IsReadOnly="True" FontFamily="Courier New" FontSize="10"
                     TextWrapping="Wrap" AcceptsReturn="True" Padding="10"
                     Background="#F9F9F9" BorderThickness="1" BorderBrush="#CCCCCC"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="15">
            <Button Content="Copy All" Padding="15,8" Click="CopyButton_Click" Margin="0,0,10,0" Background="#2C5F8A" Foreground="White"/>
            <Button Content="Close" Padding="15,8" Click="CloseButton_Click" Background="#808080" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
