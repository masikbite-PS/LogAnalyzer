<Window x:Class="LogAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LogAnalyzer"
        xmlns:converters="clr-namespace:LogAnalyzer.Converters"
        mc:Ignorable="d"
        Title="PBX Log Analyzer" Height="900" Width="1600" WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Data/loganalyzer_icon.png">
    <Window.Resources>
        <converters:DurationConverter x:Key="DurationConverter"/>
    </Window.Resources>
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="10">
            <TextBlock Text="PBX Log Analyzer" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="PBX Folder:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PbxFolderPath}" IsReadOnly="True" Padding="5" Background="#F0F0F0">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PbxFolderError}" Value="True">
                                    <Setter Property="BorderBrush" Value="Red"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <Button Grid.Row="0" Grid.Column="2" Content="Browse" Command="{Binding SelectPbxFolderCommand}" Padding="15,5" Width="100" Margin="10,0,0,0"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="SIP Folder:" VerticalAlignment="Center" Margin="0,8,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SipFolderPath}" IsReadOnly="True" Padding="5" Background="#F0F0F0" Margin="0,8,0,0">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SipFolderError}" Value="True">
                                    <Setter Property="BorderBrush" Value="Red"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <Button Grid.Row="1" Grid.Column="2" Content="Browse" Command="{Binding SelectSipFolderCommand}" Padding="15,5" Width="100" Margin="10,8,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="CallID:" VerticalAlignment="Center" Margin="0,8,10,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CallId, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,8,0,0"/>
                <Button Grid.Row="2" Grid.Column="2" Content="Analyze" Command="{Binding AnalyzeCommand}"
                        Padding="15,6" Width="110" Margin="10,8,0,0"
                        Background="#2E8540" Foreground="White" FontWeight="Bold" BorderBrush="#246B33"/>
            </Grid>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Margin="10" Background="#F5F5F5">
            <ProgressBar Height="20" Value="{Binding ProgressValue}" Maximum="100" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Export" Command="{Binding ExportLogsCommand}" Padding="15,5" Margin="10,0,0,0"/>
            </Grid>
        </StackPanel>

        <TabControl DockPanel.Dock="Top" Margin="10">
            <!-- Tab 1: Log Analysis -->
            <TabItem Header="Log Analysis" Padding="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#E0E0E0"/>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <TextBlock Text="Call Info" FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>

                            <TextBlock Text="Start Time" FontWeight="Bold" FontSize="10" Foreground="#555"/>
                            <TextBox Text="{Binding CallInfo.ServerStartDateTime, Mode=OneWay}" IsReadOnly="True" Padding="5" Margin="0,2,0,8" FontFamily="Courier New" FontSize="10" Background="#F9F9F9"/>

                            <TextBlock Text="From" FontWeight="Bold" FontSize="10" Foreground="#555"/>
                            <TextBox Text="{Binding CallInfo.CallingNumber, Mode=OneWay}" IsReadOnly="True" Padding="5" Margin="0,2,0,8" FontSize="11" Background="#F9F9F9"/>

                            <TextBlock Text="To" FontWeight="Bold" FontSize="10" Foreground="#555"/>
                            <TextBox Text="{Binding CallInfo.CalledNumber, Mode=OneWay}" IsReadOnly="True" Padding="5" Margin="0,2,0,8" FontSize="11" Background="#F9F9F9"/>

                            <TextBlock Text="User" FontWeight="Bold" FontSize="10" Foreground="#555"/>
                            <TextBox Text="{Binding CallInfo.UserLogin, Mode=OneWay}" IsReadOnly="True" Padding="5" Margin="0,2,0,8" FontSize="11" Background="#F9F9F9"/>

                            <TextBlock Text="Call Type" FontWeight="Bold" FontSize="10" Foreground="#555"/>
                            <TextBox Text="{Binding CallInfo.CallTypeName, Mode=OneWay}" IsReadOnly="True" Padding="5" Margin="0,2,0,8" FontSize="11" Background="#F9F9F9"/>

                            <TextBlock Text="Duration" FontWeight="Bold" FontSize="10" Foreground="#555"/>
                            <TextBox Text="{Binding CallInfo.Duration, StringFormat={}{0} ms, Mode=OneWay}" IsReadOnly="True" Padding="5" Margin="0,2,0,8" FontSize="11" Background="#F9F9F9"/>

                            <TextBlock Text="Channel" FontWeight="Bold" FontSize="10" Foreground="#555"/>
                            <TextBox Text="{Binding CallInfo.ChannelNumber, Mode=OneWay}" IsReadOnly="True" Padding="5" Margin="0,2,0,8" Background="#F9F9F9"/>

                            <TextBlock Text="Partner ID" FontWeight="Bold" FontSize="10" Foreground="#555"/>
                            <TextBox Text="{Binding CallInfo.PartnerPhysicalId}" IsReadOnly="True" Padding="5" Margin="0,2,0,8" FontFamily="Courier New" FontSize="9" Background="#F9F9F9" TextWrapping="Wrap"/>

                            <TextBlock Text="Sources" FontWeight="Bold" FontSize="10" Foreground="#555" Margin="0,4,0,4"/>
                            <ListBox ItemsSource="{Binding CallInfo.SourceFiles}" Height="80">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Mode=OneWay}" IsReadOnly="True" Padding="5" FontSize="9" Background="White" BorderThickness="0"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>

                    <ListBox Grid.Column="2" ItemsSource="{Binding LogEntries}" Margin="10" FontFamily="Courier New" FontSize="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Mode=OneWay}" Margin="0,0" TextWrapping="Wrap" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Foreground" Value="#000000"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Debug">
                                                    <Setter Property="TextBox.Foreground" Value="#808080"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="TextBox.Foreground" Value="#8B7500"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="TextBox.Foreground" Value="#FF0000"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Tab 2: SQL Data -->
            <TabItem Header="SQL Data" Padding="10,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="10,10,10,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Table:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding SqlDataViewModel.AvailableTables}"
                                  SelectedItem="{Binding SqlDataViewModel.SelectedTable, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="3" Content="Export to Textile"
                                Command="{Binding SqlDataViewModel.ExportToTextileCommand}"
                                Padding="15,5" Background="#2C5F8A" Foreground="White" FontWeight="Bold"/>
                    </Grid>

                    <ScrollViewer Name="SqlDataScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                        <ItemsControl ItemsSource="{Binding SqlDataViewModel.SqlRecords}" Margin="10,0,10,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,12">
                                        <Border Background="#2C5F8A" CornerRadius="3" Padding="8,4" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding RecordLabel}" Foreground="White"
                                                       FontWeight="Bold" FontSize="11"/>
                                        </Border>
                                        <DataGrid ItemsSource="{Binding Columns}" AutoGenerateColumns="False"
                                                  CanUserAddRows="False" IsReadOnly="True"
                                                  SelectionUnit="FullRow"
                                                  SelectionMode="Extended"
                                                  ClipboardCopyMode="ExcludeHeader"
                                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                                  BorderThickness="1" BorderBrush="#CCCCCC"
                                                  RowBackground="White" AlternatingRowBackground="#F8F8F8"
                                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <DataGrid.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFF1A8"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FFF1A8"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>
                                            </DataGrid.Resources>
                                            <DataGrid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Copy Field = Value" Click="SqlCopyFieldValue_Click"/>
                                                    <MenuItem Header="Copy Field" Click="SqlCopyField_Click"/>
                                                    <MenuItem Header="Copy Value" Click="SqlCopyValue_Click"/>
                                                </ContextMenu>
                                            </DataGrid.ContextMenu>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Field" Binding="{Binding Name}" Width="150"/>
                                                <DataGridTextColumn Header="Value" Binding="{Binding DisplayValue}" Width="255">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                                            <Setter Property="TextAlignment" Value="Left"/>
                                                            <Setter Property="Padding" Value="5"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>
                                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                                            <Setter Property="TextAlignment" Value="Left"/>
                                                            <Setter Property="Padding" Value="5"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2" Margin="10,4,10,6"
                               Text="{Binding SqlDataViewModel.StatusMessage}"
                               VerticalAlignment="Center" Foreground="#555"/>
                </Grid>
            </TabItem>

            <!-- Tab 3: SIP Messages -->
            <TabItem Header="SIP Messages" Padding="10,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Message List (grouped by Call-ID) and Details -->
                    <Grid Grid.Row="0" Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="400"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Grouped Message List -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                            <ItemsControl ItemsSource="{Binding SipViewModel.SipFlowGroups}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">
                                            <!-- Group Header -->
                                            <Border Background="#2C5F8A" CornerRadius="3" Padding="8,4" Margin="0,0,0,4">
                                                <StackPanel>
                                                    <TextBox Text="{Binding CallId}" IsReadOnly="True"
                                                             Background="Transparent" Foreground="White"
                                                             FontWeight="Bold" FontSize="11"
                                                             BorderThickness="0" Padding="0"
                                                             SelectionBrush="#80FFFFFF"/>
                                                    <TextBlock Text="{Binding FlowSummary}" Foreground="#C8DCF0"
                                                               FontSize="10" FontFamily="Courier New" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- Messages DataGrid -->
                                            <DataGrid ItemsSource="{Binding Messages}"
                                                      SelectionChanged="SipDataGrid_SelectionChanged"
                                                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                                      BorderThickness="1" BorderBrush="#CCCCCC"
                                                      RowBackground="White" AlternatingRowBackground="#F8F8F8"
                                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="#" Binding="{Binding SequenceNumber}" Width="35"/>
                                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="90"/>
                                                    <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="55">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="TextAlignment" Value="Center"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Method" Binding="{Binding SipMethod}" Width="*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#E0E0E0"/>

                        <!-- Right: Message Details (RawBody) -->
                        <TextBox Grid.Column="2" IsReadOnly="True" FontFamily="Courier New" FontSize="10"
                                 TextWrapping="Wrap" Padding="10"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Text="{Binding SipViewModel.SelectedMessage.RawBody, Mode=OneWay}"
                                 Background="#F9F9F9" BorderThickness="1" BorderBrush="#CCCCCC"/>
                    </Grid>

                    <!-- GridSplitter -->
                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#D0D0D0"/>

                    <!-- Merged Call Flow Diagram -->
                    <Grid Grid.Row="2" Margin="10,8,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Merged Call Flow" FontWeight="Bold" FontSize="11"
                                       Foreground="#555" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Export to Textile"
                                    Command="{Binding SipViewModel.ExportToTextileCommand}"
                                    Padding="15,5" Background="#2C5F8A" Foreground="White" FontWeight="Bold" FontSize="10"/>
                        </Grid>
                        <TextBox Grid.Row="1" IsReadOnly="True" FontFamily="Courier New" FontSize="10"
                                 TextWrapping="NoWrap" Padding="8"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 Text="{Binding SipViewModel.MergedCallFlowDiagram, Mode=OneWay}"
                                 Background="#F9F9F9" BorderThickness="1" BorderBrush="#CCCCCC"/>
                    </Grid>

                    <!-- Status -->
                    <TextBlock Grid.Row="3" Margin="10,4,10,6"
                               Text="{Binding SipViewModel.StatusMessage}"
                               VerticalAlignment="Center" Foreground="#555"/>
                </Grid>
            </TabItem>

            <!-- Tab 4: Scripts -->
            <TabItem Header="Scripts" Padding="10,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0" ItemsSource="{Binding ScriptsViewModel.ScriptsEntries}" Margin="10" FontFamily="Courier New" FontSize="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Mode=OneWay}" Margin="0,0" TextWrapping="Wrap" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Foreground" Value="#000000"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Debug">
                                                    <Setter Property="TextBox.Foreground" Value="#808080"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="TextBox.Foreground" Value="#8B7500"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="TextBox.Foreground" Value="#FF0000"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="1" Margin="10,4,10,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding ScriptsViewModel.StatusMessage}"
                                   VerticalAlignment="Center" Foreground="#555"/>
                        <Button Grid.Column="1" Content="Export scripts"
                                Command="{Binding ScriptsViewModel.ExportScriptsCommand}"
                                Padding="15,5" Background="#2C5F8A" Foreground="White" FontWeight="Bold"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
